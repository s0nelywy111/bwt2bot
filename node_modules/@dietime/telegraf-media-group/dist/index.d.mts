type ChatID = number;
type MediaGroupID = string;
type PhotoOrVideoMessage = Message.PhotoMessage | Message.VideoMessage;
declare enum CompleteKind {
    Debounced = 0,
    TimedOut = 1
}
interface MediaGroupOptions {
    timeout: number;
}
interface DelayedMediaGroupMessages {
    media_messages: PhotoOrVideoMessage[];
    complete: (kind: CompleteKind) => void;
}
declare class MediaGroup {
    options: MediaGroupOptions;
    chats: Map<ChatID, Map<MediaGroupID, DelayedMediaGroupMessages>>;
    constructor(options?: MediaGroupOptions);
    middleware(): MiddlewareFn<Context>;
}
type MediaGroupContextBase<T, U> = T & {
    update: Update & {
        media_group: U[];
    };
};
type PhotoMediaGroupContext<T> = MediaGroupContextBase<T, Message.PhotoMessage>;
type VideoMediaGroupContext<T> = MediaGroupContextBase<T, Message.VideoMessage>;
type MediaGroupContext<T> = MediaGroupContextBase<T, PhotoOrVideoMessage>;
declare const photo_media_group: () => (update: Update) => update is Update & {
    media_group: Message.PhotoMessage[];
};
declare const video_media_group: () => (update: Update) => update is Update & {
    media_group: Message.VideoMessage[];
};
declare const media_group: () => (update: Update) => update is Update & {
    media_group: PhotoOrVideoMessage[];
};

export { MediaGroup, type MediaGroupContext, type PhotoMediaGroupContext, type VideoMediaGroupContext, media_group, photo_media_group, video_media_group };
